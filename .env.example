# --- Telegram ---
BOT_TOKEN=put_telegram_bot_token_here
# Comma-separated Telegram user IDs with admin rights
ADMIN_IDS=123456789
# Drop updates that arrived while the bot was offline
DROP_PENDING_UPDATES=true

# --- Storage ---
DB_PATH=./vpnsell.db
LOG_LEVEL=INFO

# --- H1Cloud VLESS node API ---
# Base URL must include the /api suffix, e.g. https://1.2.3.4:25626/api
H1_API_URL=https://your-node-ip:25626/api
H1_API_TOKEN=put_api_token_here
# Self-signed cert on the node? Set false to skip TLS verification.
H1_VERIFY_SSL=false
H1_REQUEST_TIMEOUT=20
# Shown in the location label of VLESS link tags (informational only)
H1_NODE_NAME=Germany

# --- Subscription link shown to the customer ---
# The node subscription server: https://HOST:PORT/sub/{uuid}
SUB_PUBLIC_URL=https://your-node-ip:25627/sub/{uuid}

# --- Business rules ---
CURRENCY=RUB
# Free trial: set TRIAL_DAYS=0 to disable
TRIAL_DAYS=3
TRIAL_TRAFFIC_GB=10
TRIAL_DEVICES=1

# Tariff plans: id:title:days:price:traffic_gb:devices  (0 traffic/devices = unlimited)
# Separate plans with ';'
PLANS=m1:1 месяц:30:149:0:3;m3:3 месяца:90:399:0:3;m6:6 месяцев:180:699:0:3;m12:1 год:365:1199:0:5

# --- Crypto payments via 2328.io ---
# Master switch. Needs PAY_PROJECT_UUID + PAY_API_KEY to actually turn on.
PAY_ENABLED=false
PAY_BASE_URL=https://api.2328.io/api
# Project UUID and API key from your 2328.io project settings
PAY_PROJECT_UUID=
PAY_API_KEY=
# Sent as the User-Agent header (2328 blocks requests without one)
PAY_USER_AGENT=vpnsell/1.0 (+https://t.me)
# Currency the invoice is denominated in (fiat: RUB/USD/EUR, customer pays crypto)
PAY_CURRENCY=RUB
# Invoice lifetime in seconds (300..86400)
PAY_TTL_SECONDS=3600
# How often (seconds) the bot polls 2328.io for pending payments. Min 10.
PAY_POLL_INTERVAL=30
# Top-up button presets (in PAY_CURRENCY), comma-separated
TOPUP_AMOUNTS=100,300,500,1000
